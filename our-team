  <script>
    // Coming soon overlay — show after 5 seconds
    (function() {
      var dismissed = sessionStorage.getItem('cs-dismissed');
      var el = document.getElementById('cs-overlay');
      if (dismissed) {
        if (el) el.style.display = 'none';
      } else {
        if (el) el.style.display = 'none';
        setTimeout(function() {
          if (el) {
            el.style.display = 'flex';
            el.style.opacity = '0';
            el.classList.remove('hide');
            setTimeout(function() {
              el.style.transition = 'opacity 0.8s ease';
              el.style.opacity = '1';
            }, 30);
          }
        }, 5000);
      }
    })();

    function csDismiss() {
      var el = document.getElementById('cs-overlay');
      if (el) {
        el.classList.add('hide');
        setTimeout(function() { el.style.display = 'none'; }, 600);
      }
      sessionStorage.setItem('cs-dismissed', '1');
    }

    function csSubmit() {
      var email = document.getElementById('cs-email').value.trim();
      if (!email || !email.includes('@')) {
        alert('Please enter a valid email address.');
        return;
      }
      document.getElementById('cs-form').style.display = 'none';
      document.getElementById('cs-success').style.display = 'block';
      setTimeout(function() { csDismiss(); }, 2500);
    }
  </script>
