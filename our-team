    /* Mobile menu */
    .nav-mobile {
      display: none;
      position: fixed;
      inset: 0;
      background: var(--dark);
      z-index: 999;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 32px;
    }

    .nav-mobile.open { display: flex; }

    .nav-mobile-close {
