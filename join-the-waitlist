  <script>
    let selSvc = '', selProv = '';

    // Service card clicks
    document.querySelectorAll('.scard').forEach(function(card) {
      card.addEventListener('click', function() {
        document.querySelectorAll('.scard').forEach(function(c) { c.classList.remove('sel'); });
        card.classList.add('sel');
        selSvc = card.dataset.svc;
      });
    });

    // Provider card clicks
    document.querySelectorAll('.pcard').forEach(function(card) {
      card.addEventListener('click', function() {
        document.querySelectorAll('.pcard').forEach(function(c) { c.classList.remove('sel'); });
        card.classList.add('sel');
        selProv = card.dataset.prov;
      });
    });

    function goTo(n) {
      if (n === 2 && !selSvc) {
        alert('Please select a service to continue.');
        return;
      }
      if (n === 3 && !selProv) {
        alert('Please choose a provider to continue.');
        return;
      }
      if (n === 4) {
        var first = document.getElementById('f-first').value.trim();
        var last  = document.getElementById('f-last').value.trim();
        var phone = document.getElementById('f-phone').value.trim();
        var email = document.getElementById('f-email').value.trim();
        if (!first || !last || !phone || !email) {
          alert('Please fill in all required fields.');
          return;
        }
        document.getElementById('sum-svc').textContent  = selSvc;
        document.getElementById('sum-prov').textContent = selProv;
        document.getElementById('sum-name').textContent = first + ' ' + last;
        document.getElementById('sum-contact').textContent = phone + ' · ' + email;
        var date = document.getElementById('f-date').value;
        var time = document.getElementById('f-time').value;
        var dateStr = date
          ? new Date(date + 'T12:00:00').toLocaleDateString('en-US', { weekday:'long', month:'long', day:'numeric' })
          : 'Flexible';
        document.getElementById('sum-time').textContent = dateStr + (time ? ' · ' + time : '');
      }

      // Update step indicators
      document.querySelectorAll('.step').forEach(function(s, i) {
        s.classList.remove('active', 'done');
        if (i + 1 < n)  s.classList.add('done');
        if (i + 1 === n) s.classList.add('active');
      });

      document.querySelectorAll('.bsec').forEach(function(s) { s.classList.remove('on'); });
      document.getElementById('sec-' + n).classList.add('on');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function submitBooking() {
      var btn = document.getElementById('sub-btn');
      btn.textContent = 'Sending...';
      btn.disabled = true;
      setTimeout(function() {
        document.getElementById('bok').style.display = 'block';
        btn.textContent = 'Submitted';
      }, 1200);
    }
  </script>


  <script>
    // Coming soon overlay
    (function() {
      var dismissed = sessionStorage.getItem('cs-dismissed');
      if (dismissed) {
        var el = document.getElementById('cs-overlay');
        if (el) el.style.display = 'none';
      }
    })();

    function csDismiss() {
      var el = document.getElementById('cs-overlay');
      if (el) {
        el.classList.add('hide');
        setTimeout(function() { el.style.display = 'none'; }, 600);
      }
      sessionStorage.setItem('cs-dismissed', '1');
    }

    function csSubmit() {
      var email = document.getElementById('cs-email').value.trim();
      if (!email || !email.includes('@')) {
        alert('Please enter a valid email address.');
        return;
      }
      document.getElementById('cs-form').style.display = 'none';
      document.getElementById('cs-success').style.display = 'block';
      setTimeout(function() { csDismiss(); }, 2500);
    }
  </script>

