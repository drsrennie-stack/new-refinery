<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Book an Appointment — Refinery Aesthetics</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet"/>

  <style>
    :root {
      --dark:    #1a1a1a;
      --gold:    #c8a96e;
      --gold-lt: #e2cfa5;
      --cream:   #f0ebe3;
      --tan:     #e0d6c8;
      --white:   #faf8f4;
      --muted:   #7a7168;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Jost', sans-serif;
      font-weight: 300;
      background: var(--white);
      color: var(--dark);
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    a { text-decoration: none; color: inherit; }
    button { font-family: 'Jost', sans-serif; cursor: pointer; border: none; background: none; }


    /* ── HEADER LOGO ───────────────────────────────────────────── */
    .header-logo {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 6px;
      margin-bottom: 32px;
    }

    .header-logo-word {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(28px, 4vw, 42px);
      font-weight: 300;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--white);
      line-height: 1;
    }

    .header-logo-word.sub {
      font-size: clamp(11px, 1.4vw, 14px);
      font-weight: 400;
      letter-spacing: 0.45em;
      color: var(--gold);
      font-family: 'Jost', sans-serif;
      margin-top: 2px;
    }

    .header-logo-rule {
      width: 36px;
      height: 1px;
      background: var(--gold);
      opacity: 0.5;
      margin: 8px 0;
    }

    /* ── PAGE HEADER ───────────────────────────────────────────── */
    .page-header {
      background: var(--dark);
      padding: 80px 40px 72px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .page-header::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 70% 60% at 50% 0%, rgba(200,169,110,0.12) 0%, transparent 70%);
      pointer-events: none;
    }

    .page-header-eyebrow {
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 18px;
    }

    .header-logo {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 5px;
      margin-bottom: 36px;
    }

    .header-logo-word {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(22px, 3vw, 32px);
      font-weight: 300;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--white);
      line-height: 1;
    }

    .header-logo-rule {
      width: 30px;
      height: 1px;
      background: var(--gold);
      opacity: 0.6;
      margin: 4px 0;
    }

    .header-logo-sub {
      font-family: 'Jost', sans-serif;
      font-size: clamp(9px, 1.1vw, 11px);
      font-weight: 400;
      letter-spacing: 0.45em;
      text-transform: uppercase;
      color: var(--gold);
      line-height: 1;
    }

    .page-header h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(38px, 5.5vw, 64px);
      font-weight: 300;
      color: #ffffff;
      line-height: 1.1;
      margin-bottom: 14px;
    }

    .page-header h1 em {
      font-style: italic;
      color: var(--gold-lt);
    }

    .page-header-sub {
      font-size: 13px;
      font-weight: 300;
      color: rgba(250,248,244,0.80);
      letter-spacing: 0.04em;
    }

    .gold-rule {
      width: 48px;
      height: 1px;
      background: var(--gold);
      margin: 18px auto 0;
      opacity: 0.5;
    }

    /* ── STEP INDICATOR ────────────────────────────────────────── */
    .steps {
      display: flex;
      background: var(--tan);
      border-bottom: 1px solid var(--cream);
    }

    .step {
      flex: 1;
      padding: 18px 24px;
      display: flex;
      align-items: center;
      gap: 12px;
      border-right: 1px solid rgba(200,169,110,0.2);
      transition: background 0.3s;
    }

    .step:last-child { border-right: none; }
    .step.active { background: var(--cream); }
    .step.done { background: var(--cream); }

    .snum {
      width: 28px;
      height: 28px;
      border-radius: 50%;
      border: 1px solid rgba(200,169,110,0.4);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.05em;
      color: var(--muted);
      flex-shrink: 0;
      transition: all 0.3s;
    }

    .step.active .snum {
      background: var(--dark);
      border-color: var(--dark);
      color: var(--white);
    }

    .step.done .snum {
      background: var(--gold);
      border-color: var(--gold);
      color: var(--white);
    }

    .slbl {
      font-size: 10px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--muted);
      font-weight: 400;
    }

    .step.active .slbl { color: var(--dark); font-weight: 500; }
    .step.done .slbl { color: var(--gold); }

    /* ── FORM WRAPPER ──────────────────────────────────────────── */
    .bwrap {
      max-width: 860px;
      margin: 0 auto;
      padding: 64px 40px 100px;
    }

    .bsec { display: none; }
    .bsec.on { display: block; }

    .blbl {
      font-size: 10px;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 12px;
      font-weight: 500;
    }

    .bh {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(30px, 3.5vw, 44px);
      font-weight: 300;
      margin-bottom: 40px;
      line-height: 1.15;
      color: var(--dark);
    }

    .bh em { font-style: italic; color: var(--dark); }

    /* ── SERVICE CARDS ─────────────────────────────────────────── */
    .scards {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
      margin-bottom: 44px;
    }

    .scard {
      border: 1px solid var(--tan);
      padding: 28px 24px;
      cursor: pointer;
      transition: all 0.3s;
      position: relative;
      background: var(--white);
    }

    .scard:hover { border-color: var(--dark); background: var(--cream); }

    .scard.sel {
      border-color: var(--dark);
      background: var(--dark);
    }

    .scard-num {
      font-family: 'Cormorant Garamond', serif;
      font-size: 28px;
      font-weight: 300;
      color: rgba(200,169,110,0.4);
      line-height: 1;
      margin-bottom: 10px;
      transition: color 0.3s;
    }

    .scard.sel .scard-num { color: rgba(200,169,110,0.6); }

    .scard-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 22px;
      font-weight: 400;
      margin-bottom: 5px;
      transition: color 0.3s;
    }

    .scard.sel .scard-name { color: var(--white); }

    .scard-meta {
      font-size: 11px;
      color: var(--muted);
      letter-spacing: 0.08em;
      transition: color 0.3s;
      margin-bottom: 10px;
    }

    .scard.sel .scard-meta { color: rgba(200,169,110,0.7); }

    .scard-desc {
      font-size: 13px;
      color: var(--muted);
      line-height: 1.7;
      transition: color 0.3s;
    }

    .scard.sel .scard-desc { color: rgba(250,248,244,0.55); }

    .scard-check {
      position: absolute;
      top: 16px;
      right: 16px;
      width: 20px;
      height: 20px;
      border-radius: 50%;
      border: 1px solid var(--tan);
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.3s;
      font-size: 10px;
      color: transparent;
    }

    .scard.sel .scard-check {
      background: var(--gold);
      border-color: var(--gold);
      color: var(--white);
    }

    /* ── PROVIDER CARDS ────────────────────────────────────────── */
    .pcards {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
      margin-bottom: 44px;
    }

    .pcard {
      border: 1px solid var(--tan);
      padding: 28px 24px;
      cursor: pointer;
      transition: all 0.3s;
      background: var(--white);
      display: flex;
      gap: 18px;
      align-items: flex-start;
    }

    .pcard:hover { border-color: var(--dark); background: var(--cream); }
    .pcard.sel { border-color: var(--dark); background: var(--dark); }

    .pav {
      width: 52px;
      height: 52px;
      flex-shrink: 0;
      border-radius: 50%;
      background: var(--tan);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Cormorant Garamond', serif;
      font-size: 16px;
      font-weight: 400;
      color: var(--muted);
      border: 1px solid rgba(200,169,110,0.3);
      transition: all 0.3s;
    }

    .pcard.sel .pav {
      background: #2a2a2a;
      border-color: rgba(200,169,110,0.3);
      color: var(--gold);
    }

    .pcred {
      font-size: 10px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 4px;
      font-weight: 500;
    }

    .pname {
      font-family: 'Cormorant Garamond', serif;
      font-size: 20px;
      font-weight: 400;
      margin-bottom: 2px;
      transition: color 0.3s;
    }

    .pcard.sel .pname { color: var(--white); }

    .prole {
      font-size: 11px;
      color: var(--muted);
      margin-bottom: 8px;
      letter-spacing: 0.06em;
      transition: color 0.3s;
    }

    .pcard.sel .prole { color: rgba(200,169,110,0.7); }

    .pbio-short {
      font-size: 12.5px;
      color: var(--muted);
      line-height: 1.65;
      transition: color 0.3s;
    }

    .pcard.sel .pbio-short { color: rgba(250,248,244,0.55); }

    /* ── FORM FIELDS ───────────────────────────────────────────── */
    .fgrid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
      margin-bottom: 14px;
    }

    .fg { margin-bottom: 20px; }

    .fg label {
      display: block;
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--muted);
      font-weight: 500;
      margin-bottom: 8px;
    }

    .fg input,
    .fg select,
    .fg textarea {
      width: 100%;
      background: transparent;
      border: none;
      border-bottom: 1px solid var(--tan);
      padding: 10px 0;
      font-family: 'Jost', sans-serif;
      font-size: 14.5px;
      color: var(--dark);
      font-weight: 300;
      outline: none;
      transition: border-color 0.3s;
      -webkit-appearance: none;
      border-radius: 0;
    }

    .fg input:focus,
    .fg select:focus,
    .fg textarea:focus {
      border-color: var(--gold);
    }

    .fg textarea { resize: none; height: 80px; }

    /* ── POLICY BOX ────────────────────────────────────────────── */
    .policy {
      background: var(--cream);
      padding: 22px 24px;
      margin-bottom: 36px;
      border-left: 2px solid var(--gold);
    }

    .policy p {
      font-size: 13px;
      color: #4a4540;
      line-height: 1.8;
    }

    .policy strong { font-weight: 500; color: var(--dark); }

    /* ── SUMMARY ───────────────────────────────────────────────── */
    .summary {
      background: var(--dark);
      padding: 32px;
      margin-bottom: 32px;
    }

    .sum-row {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      padding: 14px 0;
      border-bottom: 1px solid rgba(250,248,244,0.07);
      gap: 20px;
    }

    .sum-row:last-child { border-bottom: none; }

    .sum-lbl {
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(250,248,244,0.35);
      flex-shrink: 0;
    }

    .sum-val {
      font-family: 'Cormorant Garamond', serif;
      font-size: 18px;
      font-weight: 400;
      color: var(--white);
      text-align: right;
    }

    /* ── SUCCESS MESSAGE ───────────────────────────────────────── */
    .sok {
      display: none;
      background: var(--cream);
      border-left: 2px solid var(--gold);
      padding: 18px 22px;
      font-size: 13.5px;
      color: var(--dark);
      margin-bottom: 28px;
      letter-spacing: 0.02em;
    }

    /* ── BUTTONS ───────────────────────────────────────────────── */
    .btn {
      display: inline-block;
      font-family: 'Jost', sans-serif;
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      font-weight: 500;
      padding: 14px 36px;
      transition: all 0.25s;
    }

    .bd {
      background: var(--dark);
      color: var(--white);
    }

    .bd:hover { background: #333; }

    .bo {
      background: transparent;
      color: var(--dark);
      border: 1px solid var(--tan);
    }

    .bo:hover { border-color: var(--dark); }

    .bnav {
      display: flex;
      gap: 12px;
      justify-content: space-between;
      align-items: center;
      margin-top: 8px;
    }

    /* ── FOOTER STRIPE ─────────────────────────────────────────── */
    .footer-stripe {
      background: var(--dark);
      border-top: 1px solid rgba(200,169,110,0.12);
      padding: 26px 40px;
      text-align: center;
    }

    .footer-stripe p {
      font-size: 11px;
      font-weight: 400;
      letter-spacing: 0.14em;
      color: rgba(250,248,244,0.80);
      text-transform: uppercase;
    }

    .footer-socials {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 24px;
      margin-bottom: 14px;
    }

    .footer-social {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 32px;
      height: 32px;
      border: 1px solid rgba(200,169,110,0.25);
      border-radius: 50%;
      color: rgba(250,248,244,0.40);
      transition: border-color 0.25s, color 0.25s;
      text-decoration: none;
    }

    .footer-social:hover {
      border-color: rgba(200,169,110,0.6);
      color: var(--gold);
    }

    .footer-social svg {
      width: 14px;
      height: 14px;
    }


    /* ── COMING SOON OVERLAY ───────────────────────────────────── */
    .cs-overlay {
      position: fixed;
      inset: 0;
      z-index: 9999;
      background: var(--dark);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
      text-align: center;
      opacity: 1;
      transition: opacity 0.6s ease;
    }

    .cs-overlay.hide {
      opacity: 0;
      pointer-events: none;
    }

    .cs-overlay::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 70% 50% at 50% 0%, rgba(200,169,110,0.12) 0%, transparent 70%),
        radial-gradient(ellipse 40% 40% at 80% 100%, rgba(200,169,110,0.06) 0%, transparent 60%);
      pointer-events: none;
    }

    .cs-inner {
      max-width: 520px;
      width: 100%;
      position: relative;
    }

    .cs-logo {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 6px;
      margin-bottom: 48px;
    }

    .cs-logo-word {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(28px, 4vw, 44px);
      font-weight: 300;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--white);
      line-height: 1;
    }

    .cs-logo-word.sub {
      font-size: clamp(11px, 1.4vw, 14px);
      font-weight: 400;
      letter-spacing: 0.45em;
      color: var(--gold);
      font-family: 'Jost', sans-serif;
      margin-top: 2px;
    }

    .cs-logo-rule {
      width: 36px;
      height: 1px;
      background: var(--gold);
      opacity: 0.5;
      margin: 8px 0;
    }

    .cs-eyebrow {
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 16px;
    }

    .cs-heading {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(34px, 5vw, 54px);
      font-weight: 300;
      color: var(--white);
      line-height: 1.1;
      margin-bottom: 16px;
    }

    .cs-heading em {
      font-style: italic;
      color: var(--gold-lt);
    }

    .cs-rule {
      width: 44px;
      height: 1px;
      background: var(--gold);
      opacity: 0.4;
      margin: 0 auto 24px;
    }

    .cs-sub {
      font-size: 14px;
      font-weight: 300;
      line-height: 1.8;
      color: rgba(250,248,244,0.55);
      margin-bottom: 40px;
    }

    .cs-form {
      display: flex;
      gap: 0;
      max-width: 420px;
      margin: 0 auto 20px;
    }

    .cs-input {
      flex: 1;
      background: rgba(250,248,244,0.06);
      border: 1px solid rgba(200,169,110,0.3);
      border-right: none;
      padding: 14px 18px;
      font-family: 'Jost', sans-serif;
      font-size: 13.5px;
      font-weight: 300;
      color: var(--white);
      outline: none;
      transition: border-color 0.25s;
      border-radius: 0;
      -webkit-appearance: none;
    }

    .cs-input::placeholder { color: rgba(250,248,244,0.30); }
    .cs-input:focus { border-color: rgba(200,169,110,0.7); }

    .cs-btn {
      background: var(--gold);
      color: var(--dark);
      border: 1px solid var(--gold);
      padding: 14px 24px;
      font-family: 'Jost', sans-serif;
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      cursor: pointer;
      white-space: nowrap;
      transition: background 0.25s;
      border-radius: 0;
    }

    .cs-btn:hover { background: var(--gold-lt); }

    .cs-success {
      display: none;
      font-size: 13px;
      font-weight: 300;
      color: var(--gold);
      letter-spacing: 0.08em;
      margin-bottom: 20px;
    }

    .cs-dismiss {
      display: block;
      font-size: 11px;
      font-weight: 400;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: rgba(250,248,244,0.25);
      cursor: pointer;
      background: none;
      border: none;
      transition: color 0.2s;
      margin: 0 auto;
    }

    .cs-dismiss:hover { color: rgba(250,248,244,0.55); }

    @media (max-width: 480px) {
      .cs-form { flex-direction: column; }
      .cs-input { border-right: 1px solid rgba(200,169,110,0.3); border-bottom: none; }
      .cs-btn { padding: 14px; }
    }

    /* ── RESPONSIVE ────────────────────────────────────────────── */
    @media (max-width: 700px) {
      .page-header { padding: 60px 24px 52px; }
      .steps { flex-wrap: wrap; }
      .step { flex: 1 1 50%; }
      .bwrap { padding: 44px 24px 80px; }
      .scards, .pcards { grid-template-columns: 1fr; }
      .fgrid { grid-template-columns: 1fr; }
      .bnav { flex-direction: column-reverse; align-items: stretch; }
      .bnav button { text-align: center; }
    }
  </style>
</head>
<body>

  <!-- ═══ COMING SOON OVERLAY ══════════════════════════════════════ -->
  <div class="cs-overlay" id="cs-overlay">
    <div class="cs-inner">
      <div class="cs-logo">
        <span class="cs-logo-word">Refinery</span>
        <div class="cs-logo-rule"></div>
        <span class="cs-logo-word sub">Aesthetics</span>
      </div>
      <p class="cs-eyebrow">Bancroft, Wisconsin</p>
      <h2 class="cs-heading">Something <em>refined</em><br>is coming to<br>Central Wisconsin</h2>
      <div class="cs-rule"></div>
      <p class="cs-sub">Opening Summer 2026 in Bancroft, Wisconsin.<br>Join the waitlist and be the first to book.</p>
      <div class="cs-form" id="cs-form">
        <input type="email" class="cs-input" id="cs-email" placeholder="Your email address" />
        <button class="cs-btn" onclick="csSubmit()">Notify Me</button>
      </div>
      <p class="cs-success" id="cs-success">&#10003; &nbsp; You are on the list. We will be in touch soon.</p>
      <button class="cs-dismiss" onclick="csDismiss()">I will check back later &rarr;</button>
    </div>
  </div>


  <!-- ═══ PAGE HEADER ══════════════════════════════════════════════ -->
  <header class="page-header">
    <div class="header-logo">
      <span class="header-logo-word">Refinery</span>
      <div class="header-logo-rule"></div>
      <span class="header-logo-sub">Aesthetics</span>
    </div>
    <h1>Request an<br><em>appointment</em></h1>
    <p class="page-header-sub">Complete the form below and we will confirm your booking within 24 hours.</p>
    <div class="gold-rule"></div>
  </header>

  <!-- ═══ STEP INDICATOR ═══════════════════════════════════════════ -->
  <div class="steps">
    <div class="step active" id="step-1">
      <div class="snum">1</div>
      <div class="slbl">Choose Service</div>
    </div>
    <div class="step" id="step-2">
      <div class="snum">2</div>
      <div class="slbl">Choose Provider</div>
    </div>
    <div class="step" id="step-3">
      <div class="snum">3</div>
